	<form
	    method="put"
	    action="/api/user/<?=$user->id; ?>/new_letter"
	    onsubmit="return silent_submitf(this, {after_success: profile_open_generated_letter, after_success_parameter: 'letter_file_browser'});"
	>
	    <label><?=$Dictionnary["DocumentModel"]; ?></label><br />
