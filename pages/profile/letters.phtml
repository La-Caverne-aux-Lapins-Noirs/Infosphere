<script>
 function profile_open_generated_letter(result, msg, content, parameter)
 {
     if (content && content.length)
	 window.open(content, "_blank").focus();
     let browser = document.getElementById(parameter);
     if (browser)
     {
	 let form = browser.previousElementSibling;
	 if (form)
	     silent_submit(form, parameter);
     }
 }
</script>
<div class="profile_letters">
    <h3><?=$Dictionnary["Letters"]; ?></h3>
    <?php if (!count($letter_models)) { ?>
	<p><?=$Dictionnary["NoLetterModel"]; ?></p>
