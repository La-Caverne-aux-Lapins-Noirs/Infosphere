<?php
$can_view_support_progress = function_exists("support_progress_can_view_user") &&
    support_progress_can_view_user($user->id);
$progress_rows = $can_view_support_progress ? support_progress_fetch_user_history($user->id) : [];
?>
<div class="profile_support_progress">
    <?php if (!$can_view_support_progress) { ?>
	<p>Accès non autorisé.</p>
    <?php } else if (count($progress_rows) == 0) { ?>
	<p>Aucun support consulté pour le moment.</p>
    <?php } else { ?>
	<table class="profile_support_progress_table">
	    <thead>
		<tr>
		    <th>Catégorie</th>
		    <th>Support</th>
		    <th>Chapitre</th>
		    <th>Vu</th>
		    <th>Dernière vue</th>
		</tr>
	    </thead>
	    <tbody>
		<?php foreach ($progress_rows as $row) { ?>
		    <?php
		    $pct = max(0, min(100, (int)$row["progress"]));
		    $last = $row["last_view"];
		    ?>
		    <tr>
			<td title="<?=htmlspecialchars('@'.$row['category_codename'], ENT_QUOTES, 'UTF-8'); ?>">
			    <?=htmlspecialchars($row["category_name"], ENT_QUOTES, "UTF-8"); ?>
			</td>
			<td title="<?=htmlspecialchars($row['support_codename'], ENT_QUOTES, 'UTF-8'); ?>">
			    <?=htmlspecialchars($row["support_name"], ENT_QUOTES, "UTF-8"); ?>
			</td>
			<td title="<?=htmlspecialchars('#'.$row['asset_codename'].' #'.$row['id_support_asset'], ENT_QUOTES, 'UTF-8'); ?>">
			    <?=htmlspecialchars($row["asset_name"], ENT_QUOTES, "UTF-8"); ?>
			</td>
			<td>
			    <div class="profile_support_progress_bar" title="<?=$pct; ?>%">
				<div style="width: <?=$pct; ?>%;"></div>
				<span><?=$pct; ?>%</span>
			    </div>
			</td>
			<td><?=htmlspecialchars($last, ENT_QUOTES, "UTF-8"); ?></td>
		    </tr>
		<?php } ?>
	    </tbody>
	</table>
    <?php } ?>
</div>
