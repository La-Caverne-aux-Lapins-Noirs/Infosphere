<script>
 var module_loaded_panel = {};
 var module_base_display_panel = window.display_panel;

 function module_loading_message()
 {
     return '<div style="width: 100%; text-align: center; margin-top: 20%; font-size: x-large; color: gray;">...</div>';
 }

 function module_current_target(panel, to_user)
 {
     if (panel == -1)
	 return 'resume';
     if (!to_user && localStorage.getItem('admin_module') == 1 && document.getElementById('module_' + panel + '_admin') != null)
	 return 'module_' + panel + '_admin';
     return 'module_' + panel;
 }

 function module_panel_url(target, panel)
 {
     if (target == 'resume')
	 return null;
     if (target.endsWith('_admin'))
	 return '/api/activity/' + panel + '/admin';

     let node = document.getElementById(target);
     let url = '/api/module/' + panel + '/panel';
     if (node && node.dataset && node.dataset.managed == '1')
	 url += '?managed=1';
     return url;
 }

 function module_lazy_load_panel(panel, to_user)
 {
     let target = module_current_target(panel, to_user);
     let node = document.getElementById(target);
     let url = module_panel_url(target, panel);

     if (!node || !url || module_loaded_panel[target])
	 return ;
     node.innerHTML = module_loading_message();
     send_ajax(
	 'GET',
	 url,
	 null,
	 target,
	 null,
	 null,
	 null,
	 function(success) {
	     if (!success)
		 return ;
	     module_loaded_panel[target] = true;
	     if (target.endsWith('_admin'))
		 adapt_scroll_size('' + panel);
	 }
     );
 }

 function module_display_panel(page, panel, to_admin = false, to_user = false)
 {
     if (page != 'module')
     {
	 module_base_display_panel(page, panel, to_admin, to_user);
	 return ;
     }
     if (to_admin)
	 localStorage.setItem('admin_' + page, 1);
     if (to_user)
	 localStorage.setItem('admin_' + page, 0);

     let panels = document.getElementsByClassName('module_panel');
     let links = document.getElementsByClassName('module_link');

     Array.prototype.forEach.call(panels, function(el) {
	 el.style.display = 'none';
     });
     Array.prototype.forEach.call(links, function(el) {
	 el.classList.remove('selected');
     });

     if (panel == -1)
	 document.getElementById('resume').style.display = 'block';
     else
     {
	 let target = module_current_target(panel, to_user);
	 if (target.endsWith('_admin') && document.getElementById(target) == null)
	     target = 'module_' + panel;

	 let lnk = document.getElementById(page + '_link' + panel);
	 let mod = document.getElementById(target);

	 if (lnk)
	     lnk.classList.add('selected');
	 if (mod)
	     mod.style.display = 'block';
     }

     <?php if (isset($User["id"])) { ?>
     localStorage.setItem(page + '<?=$User["id"]; ?>', panel);
     localStorage.setItem("<?=$Position; ?>_last_panel", page);
     <?php } ?>
     module_lazy_load_panel(panel, to_user);
 }

 window.display_panel = module_display_panel;

 <?php if (isset($_GET["a"])) { ?>
 display_panel("module", <?=$_GET["a"]; ?>);
 <?php } else { ?>
 var ls = localStorage.getItem('module<?=$User["id"]; ?>');
 if (ls == null)
     display_panel("module", -1);
 else
     display_panel("module", ls);
 <?php } ?>
</script>
