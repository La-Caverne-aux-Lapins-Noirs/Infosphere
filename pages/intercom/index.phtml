function intercom_page_user_can_open($type, $id)
{
    global $User;

    $id = (int)$id;
    if ($id <= 0)
        return (false);
    if (is_admin())
        return (true);
    if ($type == "common")
        return (intercom_page_common_channel($id) != NULL);
    if ($type == "school")
        return (intercom_page_school_access($id));
    if ($type == "school_staff")
        return (intercom_page_school_staff_access($id));
    if ($type == "support_asset")
        return (function_exists("support_asset_intercom_access")
            && support_asset_intercom_access($id));
    if (intercom_page_can_moderate_context($type, $id))
        return (true);
    if ($type == "cycle")
        return (intercom_page_user_is_enrolled_in_cycle($id));
    if ($type == "laboratory")
        return (is_member_of_laboratory($id));
    if ($type == "activity")
    {
        if (is_subscribed_or_assistant($id))
            return (true);
        $uid = (int)$User["id"];
        return (db_select_one("
            target.id
            FROM activity as target
            LEFT JOIN activity as source
              ON source.id = target.id
              OR source.id_template = target.id
            LEFT JOIN activity_cycle ON activity_cycle.id_activity = source.id
            LEFT JOIN user_cycle ON user_cycle.id_cycle = activity_cycle.id_cycle
            LEFT JOIN team ON team.id_activity = source.id
            LEFT JOIN user_team ON user_team.id_team = team.id
            WHERE target.id = $id
              AND (
                  user_cycle.id_user = $uid
                  OR user_team.id_user = $uid
              )
        ") != NULL);
    }
    if ($type == "team")
        return ((function_exists("is_my_team") && is_my_team($id))
            || (function_exists("is_assistant_for_team") && is_assistant_for_team($id))
            || intercom_page_can_moderate_context("team", $id));
    return (false);
}

function intercom_page_url($parameters = [])
{
    $query = [
        "p" => try_get($_GET, "p", "IntercomMenu"),
    ];
    foreach ($parameters as $key => $value)
    {
        if ($value === NULL)
            unset($query[$key]);
        else
            $query[$key] = $value;
    }
    return ("index.php?".http_build_query($query));
}

