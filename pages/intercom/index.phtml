function intercom_page_fetch_schools()
{
    global $User;

    $uid = (int)$User["id"];
    $field = $GLOBALS["Language"]."_name";
    $deleted = intercom_page_deleted_condition("school");
    if (is_admin())
        return (db_select_all("
            DISTINCT
                school.id,
                school.codename,
                school.$field as name,
                1 as staff
            FROM school
            WHERE $deleted
            ORDER BY COALESCE(NULLIF(school.$field, ''), school.codename)
        "));

    $rows = db_select_all("
        DISTINCT
            school.id,
            school.codename,
            school.$field as name,
            MAX(CASE WHEN user_school.authority > 0 THEN 1 ELSE 0 END) as school_staff
        FROM school
        LEFT JOIN user_school
          ON user_school.id_school = school.id
         AND user_school.id_user = $uid
        LEFT JOIN school_cycle
          ON school_cycle.id_school = school.id
        LEFT JOIN user_cycle
          ON user_cycle.id_cycle = school_cycle.id_cycle
         AND user_cycle.id_user = $uid
        WHERE $deleted
          AND (user_school.id_user = $uid OR user_cycle.id_user = $uid)
        GROUP BY school.id
        ORDER BY COALESCE(NULLIF(school.$field, ''), school.codename)
    ");
    $out = [];
    foreach ($rows as $row)
    {
        $row["staff"] = intercom_page_school_staff_access($row["id"]) ? 1 : (int)try_get($row, "school_staff", 0);
        $out[(int)$row["id"]] = $row;
    }

    $staff_rows = db_select_all("
        DISTINCT
            school.id,
            school.codename,
            school.$field as name,
            1 as staff
        FROM school
        LEFT JOIN school_cycle ON school_cycle.id_school = school.id
        LEFT JOIN cycle_teacher ON cycle_teacher.id_cycle = school_cycle.id_cycle
        LEFT JOIN user_laboratory as cycle_laboratory
          ON cycle_laboratory.id_laboratory = cycle_teacher.id_laboratory
         AND cycle_laboratory.id_user = $uid
         AND cycle_laboratory.authority >= 1
        LEFT JOIN school_laboratory ON school_laboratory.id_school = school.id
        LEFT JOIN user_laboratory as school_lab_member
          ON school_lab_member.id_laboratory = school_laboratory.id_laboratory
         AND school_lab_member.id_user = $uid
         AND school_lab_member.authority >= 1
        WHERE $deleted
          AND (
              cycle_teacher.id_user = $uid
              OR cycle_laboratory.id_user = $uid
              OR school_lab_member.id_user = $uid
          )
        ORDER BY COALESCE(NULLIF(school.$field, ''), school.codename)
    ");
    foreach ($staff_rows as $row)
        $out[(int)$row["id"]] = $row;

    $activity_staff_rows = db_select_all("
        DISTINCT
            school.id,
            school.codename,
            school.$field as name,
            1 as staff
        FROM activity_teacher
        LEFT JOIN activity_cycle ON activity_cycle.id_activity = activity_teacher.id_activity
        LEFT JOIN school_cycle ON school_cycle.id_cycle = activity_cycle.id_cycle
        LEFT JOIN school ON school.id = school_cycle.id_school
        LEFT JOIN user_laboratory as activity_laboratory
          ON activity_laboratory.id_laboratory = activity_teacher.id_laboratory
         AND activity_laboratory.id_user = $uid
         AND activity_laboratory.authority >= 1
        WHERE school.id IS NOT NULL
          AND $deleted
          AND (activity_teacher.id_user = $uid OR activity_laboratory.id_user = $uid)
        ORDER BY COALESCE(NULLIF(school.$field, ''), school.codename)
    ");
    foreach ($activity_staff_rows as $row)
        $out[(int)$row["id"]] = $row;

    usort($out, function($a, $b) {
        return (strcmp((string)intercom_page_label($a, ""), (string)intercom_page_label($b, "")));
    });
    return (array_values($out));
}

