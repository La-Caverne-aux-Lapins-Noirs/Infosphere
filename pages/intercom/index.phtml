    <script>
    (function() {
        if (window.__intercomIndexAjaxInstalled)
        {
            if (window.__intercomIndexBind)
                window.__intercomIndexBind();
            return;
        }
        window.__intercomIndexAjaxInstalled = true;

        function currentShell()
        {
            return document.querySelector(".intercom_page_shell");
        }

        function canAjaxNavigate(anchor)
        {
            if (!anchor || !anchor.href)
                return false;
            var url = new URL(anchor.href, window.location.href);
            if (url.origin != window.location.origin)
                return false;
            return url.searchParams.get("p") == "IntercomMenu";
        }

        function setShareFeedback(text)
        {
            var feedback = document.getElementById("intercom_share_feedback");
            if (!feedback)
                return;
            feedback.textContent = text;
            if (text)
                setTimeout(function() {
                    var current = document.getElementById("intercom_share_feedback");
                    if (current && current.textContent == text)
                        current.textContent = "";
                }, 1800);
        }

        function intercomPanelChildren(workspace)
        {
            if (!workspace)
                return [];
            return Array.prototype.filter.call(workspace.children, function(child) {
                return child.classList && child.classList.contains("intercom_nav_panel");
            });
        }

        function intercomMainPanel(workspace)
        {
            if (!workspace)
                return null;
            return workspace.querySelector(":scope > .intercom_main_panel")
                || workspace.querySelector(".intercom_main_panel");
        }

        function intercomLinkKey(anchor)
        {
            if (!anchor || !anchor.href)
                return "";
            var url = new URL(anchor.href, window.location.href);
            if (url.searchParams.get("p") != "IntercomMenu")
                return "";
            return [
                url.searchParams.get("table") || "",
                url.searchParams.get("id") || "",
                url.searchParams.get("ref") || "",
                url.searchParams.get("menu_cycle") || ""
            ].join("|");
        }

        function intercomCopyMenuAnchorState(currentPanel, nextPanel)
        {
            var current = {};
            currentPanel.querySelectorAll("a[href]").forEach(function(anchor) {
                var key = intercomLinkKey(anchor);
                if (key)
                    current[key] = anchor;
            });
            nextPanel.querySelectorAll("a[href]").forEach(function(nextAnchor) {
                var key = intercomLinkKey(nextAnchor);
                var anchor = key ? current[key] : null;
                if (!anchor)
                    return;
                anchor.className = nextAnchor.className;
                anchor.innerHTML = nextAnchor.innerHTML;
            });
        }

        function intercomCopyMatterWrapperState(currentPanel, nextPanel)
        {
            var current = {};
            currentPanel.querySelectorAll(".intercom_matter_item").forEach(function(item) {
                var link = item.querySelector("a[href]");
                var key = intercomLinkKey(link);
                if (key)
                    current[key] = item;
            });
            nextPanel.querySelectorAll(".intercom_matter_item").forEach(function(nextItem) {
                var link = nextItem.querySelector("a[href]");
                var key = intercomLinkKey(link);
                var item = key ? current[key] : null;
                if (!item)
                    return;
                item.className = nextItem.className;
            });
        }

        function intercomSyncMenuPanel(currentPanel, nextPanel)
        {
            if (!currentPanel || !nextPanel)
                return;
            intercomCopyMenuAnchorState(currentPanel, nextPanel);
            intercomCopyMatterWrapperState(currentPanel, nextPanel);
        }

        function intercomMenuCycleFromUrl(url)
        {
            var parsed = new URL(url, window.location.href);
            return parsed.searchParams.get("menu_cycle") || "";
        }

        function intercomActivateEmbeddedScripts(root)
        {
            if (!root)
                return;
            root.querySelectorAll("script").forEach(function(script) {
                var fresh = document.createElement("script");
                Array.prototype.forEach.call(script.attributes, function(attr) {
                    fresh.setAttribute(attr.name, attr.value);
                });
                fresh.text = script.textContent;
                script.replaceWith(fresh);
            });
        }

        function intercomReplaceMainPanel(workspace, nextWorkspace)
        {
            var main = intercomMainPanel(workspace);
            var nextMain = intercomMainPanel(nextWorkspace);
            if (!main || !nextMain)
                return false;
            main.replaceWith(nextMain);
            intercomActivateEmbeddedScripts(nextMain);
            return true;
        }

        function intercomUpdateSecondMenu(workspace, nextWorkspace, currentPanels, nextPanels, url)
        {
            var currentSecond = currentPanels.length > 1 ? currentPanels[1] : null;
            var nextSecond = nextPanels.length > 1 ? nextPanels[1] : null;
            var currentCycle = intercomMenuCycleFromUrl(window.location.href);
            var nextCycle = intercomMenuCycleFromUrl(url);
            var mustReplace = currentCycle != nextCycle || (!!currentSecond) != (!!nextSecond);

            if (!mustReplace)
            {
                if (currentSecond && nextSecond)
                    intercomSyncMenuPanel(currentSecond, nextSecond);
                return;
            }

            if (currentSecond && nextSecond)
                currentSecond.replaceWith(nextSecond);
            else if (!currentSecond && nextSecond)
            {
                var main = intercomMainPanel(workspace);
                if (main)
                    workspace.insertBefore(nextSecond, main);
            }
            else if (currentSecond && !nextSecond)
                currentSecond.remove();
        }

        async function loadIntercomPage(url, push)
        {
            var shell = currentShell();
            if (!shell)
            {
                window.location.href = url;
                return;
            }
            shell.classList.add("intercom_loading");
            try
            {
                var response = await fetch(url, {
                    credentials: "same-origin",
                    headers: {"X-Requested-With": "XMLHttpRequest"}
                });
                if (!response.ok)
                    throw new Error("HTTP " + response.status);
                var html = await response.text();
                var doc = new DOMParser().parseFromString(html, "text/html");
                var next = doc.querySelector(".intercom_page_shell");
                if (!next)
                    throw new Error("Missing intercom shell");

                var workspace = shell.querySelector(".intercom_workspace");
                var nextWorkspace = next.querySelector(".intercom_workspace");
                if (!workspace || !nextWorkspace)
                    throw new Error("Missing intercom workspace");

                var currentPanels = intercomPanelChildren(workspace);
                var nextPanels = intercomPanelChildren(nextWorkspace);
                if (currentPanels[0] && nextPanels[0])
                    intercomSyncMenuPanel(currentPanels[0], nextPanels[0]);
                intercomUpdateSecondMenu(workspace, nextWorkspace, currentPanels, nextPanels, url);
                workspace.className = nextWorkspace.className;

                if (!intercomReplaceMainPanel(workspace, nextWorkspace))
                    throw new Error("Missing intercom main panel");
                if (push)
                    history.pushState({intercom: true}, "", url);
                bindIntercomIndex();
            }
            catch (err)
            {
                window.location.href = url;
            }
            finally
            {
                var current = currentShell();
                if (current)
                    current.classList.remove("intercom_loading");
            }
        }

        function shareCurrentIntercom()
        {
            var url = window.location.href;
            if (navigator.clipboard && navigator.clipboard.writeText)
                navigator.clipboard.writeText(url).then(function() {
                    setShareFeedback("Lien copié");
                }, function() {
                    prompt("Lien à partager", url);
                });
            else
                prompt("Lien à partager", url);
        }


        function intercomNormalizeSearch(value)
        {
            return (value || "")
                .toString()
                .toLocaleLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .trim();
        }

        function directSearchItems(section)
        {
            return Array.prototype.filter.call(section.children, function(child) {
                return child.classList
                    && (child.classList.contains("intercom_nav_item")
                        || child.classList.contains("intercom_matter_item"));
            });
        }

        function directSearchEmpty(section)
        {
            var found = null;
            Array.prototype.forEach.call(section.children, function(child) {
                if (child.classList && child.classList.contains("intercom_search_empty"))
                    found = child;
            });
            if (!found)
            {
                found = document.createElement("p");
                found.className = "intercom_search_empty";
                found.textContent = "Aucun résultat.";
                section.appendChild(found);
            }
            return found;
        }

        function bindIntercomMenuSearch(shell)
        {
            shell.querySelectorAll(".intercom_nav_panel").forEach(function(panel) {
                var input = panel.querySelector("[data-intercom-menu-search]");
                if (!input || input.dataset.intercomSearchBound)
                    return;
                input.dataset.intercomSearchBound = "1";

                function applySearch()
                {
                    var term = intercomNormalizeSearch(input.value);
                    panel.querySelectorAll(".intercom_nav_section").forEach(function(section) {
                        var items = directSearchItems(section);
                        var any = false;
                        items.forEach(function(item) {
                            var text = intercomNormalizeSearch(item.textContent);
                            var match = !term || text.indexOf(term) != -1;
                            item.classList.toggle("intercom_search_hidden", !match);
                            if (match)
                            {
                                any = true;
                                if (term)
                                    item.querySelectorAll("details").forEach(function(details) {
                                        details.open = true;
                                    });
                            }
                        });
                        directSearchEmpty(section);
                        section.classList.toggle(
                            "intercom_search_section_empty",
                            !!term && items.length > 0 && !any
                        );
                    });
                }

                input.addEventListener("input", applySearch);
                applySearch();
            });
        }

        function bindIntercomIndex()
        {
            var shell = currentShell();
            if (!shell)
                return;
            bindIntercomMenuSearch(shell);
            shell.querySelectorAll("a[href]").forEach(function(anchor) {
                if (anchor.dataset.intercomAjaxBound || !canAjaxNavigate(anchor))
                    return;
                anchor.dataset.intercomAjaxBound = "1";
                anchor.addEventListener("click", function(event) {
                    if (event.defaultPrevented || event.button != 0 || event.ctrlKey || event.metaKey || event.shiftKey || event.altKey)
                        return;
                    event.preventDefault();
                    loadIntercomPage(anchor.href, true);
                });
            });
            var share = document.getElementById("intercom_share_button");
            if (share && !share.dataset.intercomShareBound)
            {
                share.dataset.intercomShareBound = "1";
                share.addEventListener("click", shareCurrentIntercom);
            }
        }

        window.__intercomIndexBind = bindIntercomIndex;
        window.addEventListener("popstate", function() {
            loadIntercomPage(window.location.href, false);
        });
        bindIntercomIndex();
    })();
    </script>
    <?php
}
?>

<?php intercom_page_display_shell(); ?>
