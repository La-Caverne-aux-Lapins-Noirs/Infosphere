function intercom_page_fetch_cycle_activities($id_cycle)
{
    global $User;

    $uid = (int)$User["id"];
    $id_cycle = (int)$id_cycle;
    $field = $GLOBALS["Language"]."_name";
    $source_ok = intercom_page_deleted_condition("source");
    $matter_ok = intercom_page_deleted_condition("matter_source");
    $target_ok = intercom_page_deleted_condition("target");

    $matter_name = "COALESCE(
        NULLIF(target.$field, ''),
        NULLIF(matter_source.$field, ''),
        NULLIF(source.$field, ''),
        NULLIF(target.codename, ''),
        NULLIF(matter_source.codename, ''),
        source.codename
    )";

    $full_cycle_access = intercom_page_user_is_enrolled_in_cycle($id_cycle)
        || intercom_page_can_moderate_context("cycle", $id_cycle);

    if ($full_cycle_access)
        $scope_where = "1";
    else
        $scope_where = "EXISTS (
            SELECT 1
            FROM activity_teacher as managed_teacher
            LEFT JOIN user_laboratory as managed_laboratory
              ON managed_laboratory.id_laboratory = managed_teacher.id_laboratory
             AND managed_laboratory.id_user = $uid
             AND managed_laboratory.authority >= 1
            LEFT JOIN activity as managed_source
              ON managed_source.id = managed_teacher.id_activity
            LEFT JOIN activity as managed_matter_source
              ON managed_matter_source.id = CASE
                  WHEN managed_source.parent_activity IS NOT NULL AND managed_source.parent_activity != -1
                      THEN managed_source.parent_activity
                  ELSE managed_source.id
              END
            LEFT JOIN activity as managed_target
              ON managed_target.id = CASE
                  WHEN managed_matter_source.id_template IS NOT NULL AND managed_matter_source.id_template != -1
                      THEN managed_matter_source.id_template
                  ELSE managed_matter_source.id
              END
            WHERE (managed_teacher.id_user = $uid OR managed_laboratory.id_user = $uid)
              AND managed_target.id = target.id
        )";

    return (db_select_all("
        DISTINCT
            target.id as id,
            target.codename as codename,
            $matter_name as name,
            matter_source.id as instance_id
        FROM activity_cycle
        LEFT JOIN activity as source
          ON source.id = activity_cycle.id_activity
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        WHERE activity_cycle.id_cycle = $id_cycle
          AND $scope_where
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND (target.parent_activity IS NULL OR target.parent_activity = -1)
          AND $source_ok
          AND $matter_ok
          AND $target_ok
        ORDER BY
            $matter_name
    "));
}

function intercom_page_fetch_cycle_matter_teams($id_cycle)
{
    global $User;

    $uid = (int)$User["id"];
    $id_cycle = (int)$id_cycle;
    $field = $GLOBALS["Language"]."_name";
    $source_ok = intercom_page_deleted_condition("source");
    $matter_ok = intercom_page_deleted_condition("matter_source");
    $target_ok = intercom_page_deleted_condition("target");
    $cycle_manager = intercom_page_can_moderate_context("cycle", $id_cycle);

    $matter_name = "COALESCE(
        NULLIF(target.$field, ''),
        NULLIF(matter_source.$field, ''),
        NULLIF(source.$field, ''),
        NULLIF(target.codename, ''),
        NULLIF(matter_source.codename, ''),
        source.codename
    )";
    $project_name = "COALESCE(
        NULLIF(source.$field, ''),
        NULLIF(source_template.$field, ''),
        NULLIF(matter_source.$field, ''),
        NULLIF(target.$field, ''),
        NULLIF(source.codename, ''),
        NULLIF(source_template.codename, ''),
        NULLIF(matter_source.codename, ''),
        target.codename
    )";

    $scope_where = $cycle_manager ? "1" : "(
        user_team.id_user = $uid
        OR activity_teacher.id_user = $uid
        OR activity_laboratory.id_user = $uid
    )";

    $rows = db_select_all("
        DISTINCT
            target.id as matter_id,
            $matter_name as matter_name,
            source.id as activity_id,
            $project_name as activity_name,
            team.id as id,
            COALESCE(NULLIF(team.team_name, ''), CONCAT('Equipe #', team.id)) as name,
            COALESCE(team_members.member_count, 0) as member_count
        FROM team
        LEFT JOIN user_team ON user_team.id_team = team.id
        LEFT JOIN (
            SELECT id_team, COUNT(DISTINCT id_user) as member_count
            FROM user_team
            GROUP BY id_team
        ) as team_members ON team_members.id_team = team.id
        LEFT JOIN activity as source ON source.id = team.id_activity
        LEFT JOIN activity as source_template ON source_template.id = source.id_template
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity_cycle
          ON activity_cycle.id_activity = source.id
          OR activity_cycle.id_activity = matter_source.id
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        LEFT JOIN activity_teacher
          ON activity_teacher.id_activity = source.id
          OR activity_teacher.id_activity = matter_source.id
          OR activity_teacher.id_activity = target.id
        LEFT JOIN user_laboratory as activity_laboratory
          ON activity_laboratory.id_laboratory = activity_teacher.id_laboratory
         AND activity_laboratory.id_user = $uid
         AND activity_laboratory.authority >= 1
        WHERE activity_cycle.id_cycle = $id_cycle
          AND $scope_where
          AND team.id IS NOT NULL
          AND COALESCE(team_members.member_count, 0) > 1
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND (team.closed IS NULL OR team.closed = 0)
          AND $source_ok
          AND $matter_ok
          AND $target_ok
          AND (source.emergence_date IS NULL OR source.emergence_date <= NOW())
          AND (source.close_date IS NULL OR source.close_date >= NOW())
          AND (source.done_date IS NULL OR source.done_date >= NOW())
        ORDER BY $matter_name,
                 COALESCE(source.close_date, source.done_date, '9999-12-31'),
                 $project_name,
                 name
    ");

    $ret = [];
    foreach ($rows as $row)
    {
        $matter = (int)$row["matter_id"];
        $activity = (int)$row["activity_id"];
        if (!isset($ret[$matter]))
            $ret[$matter] = [];
        if (!isset($ret[$matter][$activity]))
            $ret[$matter][$activity] = [
                "id" => $activity,
                "name" => $row["activity_name"],
                "team_count" => 0,
                "teams" => [],
            ];
        $ret[$matter][$activity]["team_count"] += 1;
        $ret[$matter][$activity]["teams"][] = $row;
    }
    foreach ($ret as $matter => $projects)
        $ret[$matter] = array_values($projects);
    return ($ret);
}

