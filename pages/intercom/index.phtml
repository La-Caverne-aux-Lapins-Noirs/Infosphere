function intercom_page_last_message($type, $id)
{
    global $Database;

    $type = $Database->real_escape_string($type);
    $id = (int)$id;
    return (db_select_one("
        
            message.id,
            message.title,
            message.message,
            message.post_date,
            author.nickname,
            author.codename
        FROM message
        LEFT JOIN message as root ON root.id = message.id_message
        LEFT JOIN user as author ON author.id = message.id_user
        WHERE (
              message.misc_type = '$type'
              AND message.id_misc = $id
              AND message.id_message IS NULL
          ) OR (
              root.misc_type = '$type'
              AND root.id_misc = $id
          )
        ORDER BY message.post_date DESC, message.id DESC
    "));
}


function intercom_page_unread_count($type, $id)
{
    global $Database;
    global $User;

    static $cache = [];

    if (!$User)
        return (0);
    $type = (string)$type;
    $id = (int)$id;
    if ($id <= 0 || $type == "")
        return (0);
    if ($type == "support_asset" && function_exists("support_asset_intercom_unread_count"))
        return (support_asset_intercom_unread_count($id));
    $key = $type."/".$id;
    if (isset($cache[$key]))
        return ($cache[$key]);

    $etype = $Database->real_escape_string($type);
    $uid = (int)$User["id"];
    $can_moderate = intercom_page_can_moderate_context($type, $id);
    $hidden_root_filter = "";
    $hidden_item_filter = "";
    if (!$can_moderate)
    {
        $hidden_root_filter = "
          AND NOT EXISTS (
              SELECT 1 FROM message_report as hidden_root
              WHERE hidden_root.id_message = root.id
                AND hidden_root.status = -1
          )";
        $hidden_item_filter = "
              AND NOT EXISTS (
                  SELECT 1 FROM message_report as hidden_item
                  WHERE hidden_item.id_message = item.id
                    AND hidden_item.status = -1
              )";
    }

    $row = db_select_one("
        COUNT(DISTINCT root.id) as cnt
        FROM message as root
        LEFT JOIN message_user as viewed
          ON viewed.id_message = root.id
         AND viewed.id_user = $uid
        WHERE root.misc_type = '$etype'
          AND root.id_misc = $id
          AND root.id_message IS NULL
          $hidden_root_filter
          AND EXISTS (
              SELECT 1
              FROM message as item
              WHERE (item.id = root.id OR item.id_message = root.id)
                AND item.id_user != $uid
                AND (viewed.view_date IS NULL OR item.post_date > viewed.view_date)
                $hidden_item_filter
          )
    ");
    $cache[$key] = $row == NULL ? 0 : (int)$row["cnt"];
    return ($cache[$key]);
}

