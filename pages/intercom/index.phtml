function intercom_page_label($row, $fallback = "")
{
    global $Language;

    if (isset($row["name"]) && strlen(trim((string)$row["name"])))
        return ($row["name"]);
    if (isset($row[$Language."_name"]) && strlen(trim((string)$row[$Language."_name"])))
        return ($row[$Language."_name"]);
    if (isset($row["codename"]) && strlen(trim((string)$row["codename"])))
        return ($row["codename"]);
    return ($fallback);
}

function intercom_page_h($value)
{
    return (htmlentities((string)$value));
}

function intercom_page_deleted_condition($alias)
{
    return ("($alias.deleted IS NULL OR $alias.deleted = 0)");
}

function intercom_page_name_sql($alias)
{
    global $Language;

    $field = $Language."_name";
    return ("COALESCE(NULLIF($alias.$field, ''), $alias.codename)");
}

function intercom_page_laboratory_authority($id_laboratory)
{
    if (function_exists("intercom_laboratory_authority_for_current_user"))
        return (intercom_laboratory_authority_for_current_user($id_laboratory));

    global $User;

    $id_laboratory = (int)$id_laboratory;
    $row = db_select_one("
        authority FROM user_laboratory
        WHERE id_user = ".((int)$User["id"])."
          AND id_laboratory = $id_laboratory
    ");
    if ($row == NULL)
        return (-1);
    return ((int)$row["authority"]);
}

function intercom_page_cycle_is_current_condition($alias)
{
    return ("($alias.first_day IS NULL OR DATE_ADD($alias.first_day, INTERVAL 15 WEEK) >= NOW())");
}

function intercom_page_user_is_enrolled_in_cycle($id_cycle)
{
    global $User;

    $id_cycle = (int)$id_cycle;
    return (db_select_one("
        id FROM user_cycle
        WHERE id_user = ".((int)$User["id"])."
          AND id_cycle = $id_cycle
    ") != NULL);
}

function intercom_page_has_managed_activity_in_cycle($id_cycle)
{
    global $User;

    if (is_admin())
        return (true);
    $uid = (int)$User["id"];
    $id_cycle = (int)$id_cycle;
    $source_ok = intercom_page_deleted_condition("source");
    $matter_ok = intercom_page_deleted_condition("matter_source");
    $target_ok = intercom_page_deleted_condition("target");

    return (db_select_one("
        activity_teacher.id
        FROM activity_teacher
        LEFT JOIN user_laboratory as activity_laboratory
          ON activity_laboratory.id_laboratory = activity_teacher.id_laboratory
         AND activity_laboratory.id_user = $uid
         AND activity_laboratory.authority >= 1
        LEFT JOIN activity as source
          ON source.id = activity_teacher.id_activity
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        LEFT JOIN activity_cycle
          ON activity_cycle.id_activity = source.id
          OR activity_cycle.id_activity = matter_source.id
          OR activity_cycle.id_activity = target.id
        WHERE activity_cycle.id_cycle = $id_cycle
          AND (activity_teacher.id_user = $uid OR activity_laboratory.id_user = $uid)
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND $source_ok
          AND $matter_ok
          AND $target_ok
    ") != NULL);
}

function intercom_page_can_moderate_context($type, $id)
{
    global $User;

    if (!$User)
        return (false);
    if (function_exists("intercom_can_moderate_context"))
        return (intercom_can_moderate_context($type, $id));
    if (is_admin())
        return (true);
    $id = (int)$id;
    if ($type == "cycle")
        return (is_director_for_cycle($id));
    if ($type == "laboratory_public")
        return (function_exists("intercom_can_moderate_laboratory_public")
            ? intercom_can_moderate_laboratory_public($id)
            : intercom_page_laboratory_authority($id) >= 1);
    if ($type == "laboratory")
        return (intercom_page_laboratory_authority($id) >= 2);
    if ($type == "support_asset")
        return (function_exists("support_asset_intercom_can_moderate")
            && support_asset_intercom_can_moderate($id));
    if ($type == "activity")
        return ((function_exists("is_teacher_or_director_for_activity") && is_teacher_or_director_for_activity($id))
            || (function_exists("is_assistant_for_activity") && is_assistant_for_activity($id)));
    if ($type == "team")
    {
        if (function_exists("is_assistant_for_team") && is_assistant_for_team($id))
            return (true);
        $team = db_select_one("id_activity FROM team WHERE id = $id");
        if ($team == NULL)
            return (false);
        return (intercom_page_can_moderate_context("activity", $team["id_activity"]));
    }
    if ($type == "user")
        return (is_director_for_student($id)
            || is_cycle_director_for_student($id)
            || is_teacher_for_student($id));
    return (false);
}

function intercom_page_has_moderation_scope()
{
    global $User;

    if (is_admin())
        return (true);
    $uid = (int)$User["id"];
    if (db_select_one("
        cycle_teacher.id
        FROM cycle_teacher
        LEFT JOIN cycle ON cycle.id = cycle_teacher.id_cycle
        LEFT JOIN user_laboratory as cycle_laboratory
          ON cycle_laboratory.id_laboratory = cycle_teacher.id_laboratory
         AND cycle_laboratory.id_user = $uid
         AND cycle_laboratory.authority >= 1
        WHERE (cycle_teacher.id_user = $uid OR cycle_laboratory.id_user = $uid)
          AND cycle.id IS NOT NULL
          AND ".intercom_page_deleted_condition("cycle")."
          AND ".intercom_page_cycle_is_current_condition("cycle")."
    ") != NULL)
        return (true);
    if (db_select_one("
        activity_teacher.id
        FROM activity_teacher
        LEFT JOIN activity ON activity.id = activity_teacher.id_activity
        LEFT JOIN user_laboratory as activity_laboratory
          ON activity_laboratory.id_laboratory = activity_teacher.id_laboratory
         AND activity_laboratory.id_user = $uid
         AND activity_laboratory.authority >= 1
        WHERE (activity_teacher.id_user = $uid OR activity_laboratory.id_user = $uid)
          AND activity.id IS NOT NULL
          AND ".intercom_page_deleted_condition("activity")."
    ") != NULL)
        return (true);
    if (db_select_one("
        id FROM user_laboratory
        WHERE id_user = $uid
          AND authority >= 2
    ") != NULL)
        return (true);
    return (false);
}

function intercom_page_fetch_reports()
{
    $rows = db_select_all("
        message_report.id_message as id_message,
        COUNT(*) as report_count,
        MIN(message_report.postdate) as first_report_date,
        MAX(message_report.postdate) as last_report_date,
        reported.id as reported_message_id,
        reported.id_user as reported_user_id,
        reported.title as reported_title,
        reported.message as reported_message,
        reported.post_date as reported_post_date,
        COALESCE(root.id, reported.id) as subject_id,
        COALESCE(root.title, reported.title) as subject_title,
        COALESCE(root.misc_type, reported.misc_type) as misc_type,
        COALESCE(root.id_misc, reported.id_misc) as id_misc,
        author.nickname as author_nickname,
        author.codename as author_codename
        FROM message_report
        LEFT JOIN message as reported ON reported.id = message_report.id_message
        LEFT JOIN message as root ON root.id = reported.id_message
        LEFT JOIN user as author ON author.id = reported.id_user
        WHERE message_report.status = 0
          AND reported.id IS NOT NULL
        GROUP BY message_report.id_message
        ORDER BY MAX(message_report.postdate) DESC
        LIMIT 100
    ");

    if (is_admin())
        return ($rows);
    $ret = [];
    foreach ($rows as $row)
        if (intercom_page_can_moderate_context($row["misc_type"], $row["id_misc"]))
            $ret[] = $row;
    return ($ret);
}

