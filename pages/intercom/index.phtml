function intercom_page_fetch_cycles()
{
    global $User;

    $uid = (int)$User["id"];
    $field = $GLOBALS["Language"]."_name";
    $cycle_ok = intercom_page_deleted_condition("cycle");
    $cycle_current = intercom_page_cycle_is_current_condition("cycle");
    $cycles = [];

    $add = function($row, $managed = false) use (&$cycles) {
        $id = (int)$row["id"];
        if ($id <= 0)
            return ;
        if (!isset($cycles[$id]))
            $cycles[$id] = $row;
        if ($managed)
            $cycles[$id]["managed"] = 1;
        else if (!isset($cycles[$id]["managed"]))
            $cycles[$id]["managed"] = 0;
    };

    foreach (db_select_all("
        DISTINCT
            cycle.id,
            cycle.codename,
            cycle.$field as name,
            cycle.first_day
        FROM user_cycle
        LEFT JOIN cycle ON cycle.id = user_cycle.id_cycle
        WHERE user_cycle.id_user = $uid
          AND cycle.id IS NOT NULL
          AND $cycle_ok
    ") as $cycle)
        $add($cycle, false);

    foreach (db_select_all("
        DISTINCT
            cycle.id,
            cycle.codename,
            cycle.$field as name,
            cycle.first_day
        FROM cycle_teacher
        LEFT JOIN cycle ON cycle.id = cycle_teacher.id_cycle
        LEFT JOIN user_laboratory as cycle_laboratory
          ON cycle_laboratory.id_laboratory = cycle_teacher.id_laboratory
         AND cycle_laboratory.id_user = $uid
         AND cycle_laboratory.authority >= 1
        WHERE (cycle_teacher.id_user = $uid OR cycle_laboratory.id_user = $uid)
          AND cycle.id IS NOT NULL
          AND $cycle_ok
          AND $cycle_current
    ") as $cycle)
        $add($cycle, true);

    $source_ok = intercom_page_deleted_condition("source");
    $matter_ok = intercom_page_deleted_condition("matter_source");
    $target_ok = intercom_page_deleted_condition("target");
    foreach (db_select_all("
        DISTINCT
            cycle.id,
            cycle.codename,
            cycle.$field as name,
            cycle.first_day
        FROM activity_teacher
        LEFT JOIN user_laboratory as activity_laboratory
          ON activity_laboratory.id_laboratory = activity_teacher.id_laboratory
         AND activity_laboratory.id_user = $uid
         AND activity_laboratory.authority >= 1
        LEFT JOIN activity as source ON source.id = activity_teacher.id_activity
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        LEFT JOIN activity_cycle
          ON activity_cycle.id_activity = source.id
          OR activity_cycle.id_activity = matter_source.id
          OR activity_cycle.id_activity = target.id
        LEFT JOIN cycle ON cycle.id = activity_cycle.id_cycle
        WHERE (activity_teacher.id_user = $uid OR activity_laboratory.id_user = $uid)
          AND cycle.id IS NOT NULL
          AND $cycle_ok
          AND $cycle_current
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND $source_ok
          AND $matter_ok
          AND $target_ok
    ") as $cycle)
        $add($cycle, true);

    usort($cycles, function($a, $b) {
        $ad = try_get($a, "first_day", "9999-12-31");
        $bd = try_get($b, "first_day", "9999-12-31");
        if ($ad == $bd)
            return (strcmp((string)try_get($a, "codename", ""), (string)try_get($b, "codename", "")));
        return (strcmp((string)$ad, (string)$bd));
    });
    return (array_values($cycles));
}

function intercom_page_fetch_activities()
{
    global $User;

    $uid = (int)$User["id"];
    $name_target = intercom_page_name_sql("target");
    $source_ok = intercom_page_deleted_condition("source");
    $matter_ok = intercom_page_deleted_condition("matter_source");
    $target_ok = intercom_page_deleted_condition("target");

    // On ne liste pas les activités fines / projets / sessions: on remonte
    // toujours à la matière porteuse, puis à son modèle si elle en a un.
    $from_teams = "
        DISTINCT
            target.id as id,
            target.codename as codename,
            $name_target as name
        FROM user_team
        LEFT JOIN team ON team.id = user_team.id_team
        LEFT JOIN activity as source ON source.id = team.id_activity
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        WHERE user_team.id_user = $uid
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND (target.parent_activity IS NULL OR target.parent_activity = -1)
          AND $source_ok
          AND $matter_ok
          AND $target_ok
    ";

    $from_cycles = "
        DISTINCT
            target.id as id,
            target.codename as codename,
            $name_target as name
        FROM user_cycle
        LEFT JOIN activity_cycle ON activity_cycle.id_cycle = user_cycle.id_cycle
        LEFT JOIN activity as source ON source.id = activity_cycle.id_activity
        LEFT JOIN activity as matter_source
          ON matter_source.id = CASE
              WHEN source.parent_activity IS NOT NULL AND source.parent_activity != -1
                  THEN source.parent_activity
              ELSE source.id
          END
        LEFT JOIN activity as target
          ON target.id = CASE
              WHEN matter_source.id_template IS NOT NULL AND matter_source.id_template != -1
                  THEN matter_source.id_template
              ELSE matter_source.id
          END
        WHERE user_cycle.id_user = $uid
          AND source.id IS NOT NULL
          AND matter_source.id IS NOT NULL
          AND target.id IS NOT NULL
          AND (target.parent_activity IS NULL OR target.parent_activity = -1)
          AND $source_ok
          AND $matter_ok
          AND $target_ok
    ";

    return (db_select_all("
        DISTINCT id, codename, name
        FROM (
            SELECT $from_teams
            UNION
            SELECT $from_cycles
        ) as available_activity_intercoms
        ORDER BY
        COALESCE(
            NULLIF(target.fr_name, ''),
            target.codename
        )
    "));
}


function intercom_page_fetch_public_laboratories()
{
    global $User;
    global $Language;

    $uid = (int)$User["id"];
    $name = "laboratory.".$Language."_name";
    $deleted = intercom_page_deleted_condition("laboratory");
    $access = is_admin()
        ? "1"
        : "(user_school.id_user IS NOT NULL OR user_cycle.id_user IS NOT NULL OR user_laboratory.id_user IS NOT NULL)";

    return (db_select_all("\n        DISTINCT\n            laboratory.id,\n            laboratory.codename,\n            $name as name,\n            'Salon public du laboratoire' as context\n        FROM laboratory\n        LEFT JOIN school_laboratory\n          ON school_laboratory.id_laboratory = laboratory.id\n        LEFT JOIN user_school\n          ON user_school.id_school = school_laboratory.id_school\n         AND user_school.id_user = $uid\n        LEFT JOIN school_cycle\n          ON school_cycle.id_school = school_laboratory.id_school\n        LEFT JOIN user_cycle\n          ON user_cycle.id_cycle = school_cycle.id_cycle\n         AND user_cycle.id_user = $uid\n        LEFT JOIN user_laboratory\n          ON user_laboratory.id_laboratory = laboratory.id\n         AND user_laboratory.id_user = $uid\n        WHERE laboratory.id IS NOT NULL\n          AND $deleted\n          AND $access\n        ORDER BY COALESCE(NULLIF($name, ''), laboratory.codename)\n    "));
}

