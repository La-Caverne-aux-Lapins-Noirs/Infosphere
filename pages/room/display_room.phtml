<?php
$room_presences = [];
foreach ($room["desk"] as $presence_desk)
{
    foreach ($presence_desk["users"] as $presence_user)
    {
        if ($presence_user["id"] == NULL)
            continue ;
        $presence_key = $presence_user["id"]."-".$presence_desk["id"]."-".(int)$presence_user["distant"]."-".(int)$presence_user["locked"];
        $room_presences[$presence_key] = [
            "desk" => $presence_desk,
            "user" => $presence_user,
        ];
    }
}

$room_user_status_label = function ($usr) use ($Dictionnary)
{
    if (!empty($usr["distant"]) && !empty($usr["locked"]))
        return (isset($Dictionnary["SSHIdle"]) ? $Dictionnary["SSHIdle"] : "SSH idle");
    if (!empty($usr["distant"]))
        return (isset($Dictionnary["SSHOnly"]) ? $Dictionnary["SSHOnly"] : "SSH");
    if (!empty($usr["locked"]))
        return (isset($Dictionnary["Locked"]) ? $Dictionnary["Locked"] : "Locked");
    return (isset($Dictionnary["Used"]) ? $Dictionnary["Used"] : "Used");
};
?>
