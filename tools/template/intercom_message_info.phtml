<?php /* intercom_message_info_moderation_defaults */
if (function_exists("intercom_prepare_message_for_display")
    && (!isset($message["can_moderate"]) || !isset($message["is_moderated"])))
    intercom_prepare_message_for_display($message);
if (!isset($message["can_moderate"]))
    $message["can_moderate"] = false;
if (!isset($message["is_moderated"]))
    $message["is_moderated"] = false;
if (!isset($message["reported_by_user"]))
    $message["reported_by_user"] = false;
if (!isset($message["report_count"]))
    $message["report_count"] = 0;
?>
<div
    style="
	   width: 110px;
	   min-height: 100px;
	   <?php if ($message["id_user"] != $User["id"]) { ?>
	   float: left;
	   text-align: left;
	   <?php } else { ?>
	   float: right;
	   text-align: right;
	   <?php } ?>
	   "
>
    <?php display_avatar($message["id_user"], 100); ?>
</div>
<div style="
	    width: calc(100% - 120px);
	    margin-left: 10px;
	    margin-right: 10px;
	    height: 20px;
	    <?php if ($message["id_user"] != $User["id"]) { ?>
	    text-align: left;
	    <?php } else { ?>
	    text-align: right;
	    <?php } ?>
	    "
>
    <?php display_nickname($message["id_user"]); ?>
    <?=human_date($message["post_date"]); ?>
</div>


<?php
$intercom_moderation_action = intercom_api_url_html($intercom, $message["id"]);
$intercom_moderation_js = "silent_submitf(this, {tofill: '".$intercom["div"]."_msg'});";
?>
<div
    class="intercom_moderation_buttons"
    style="
           /* intercom_moderation_buttons_topright_v2 */
           position: absolute;
           top: 28px;
           <?php if ($message["id_user"] == $User["id"]) { ?>
           right: 120px;
           <?php } else { ?>
           right: 8px;
           <?php } ?>
           z-index: 6;
           max-width: min(360px, calc(100% - 150px));
           text-align: right;
           display: flex;
           flex-direction: row;
           align-items: center;
           justify-content: flex-end;
           gap: 4px;
           flex-wrap: wrap;
           padding: 2px 4px;
           border-radius: 6px;
           background: rgba(0, 0, 0, 0.32);
           font-size: x-small;
           "
>
    <?php if ($message["can_moderate"]) { ?>
        <?php if ($message["report_count"] > 0) { ?>
            <span style="font-size: x-small; opacity: 1; font-weight: bold;">
                ⚠ <?=$message["report_count"]; ?> <?=$Dictionnary["IntercomActiveReports"]; ?>
            </span>
            <form
                method="post"
                action="<?=$intercom_moderation_action; ?>"
                onsubmit="return <?=$intercom_moderation_js; ?>"
                style="display: inline-block; margin-left: 4px;"
            >
                <input type="hidden" name="intercom_action" value="close_reports" />
                <input type="hidden" name="current_subject" value="<?=$subject["id"]; ?>" />
                <input
                    type="button"
                    onclick="<?=$intercom_moderation_js; ?>"
                    value="<?=$Dictionnary["CloseIntercomReports"]; ?>"
                    style="font-size: x-small; min-height: 20px;"
                />
            </form>
        <?php } ?>
        <form
            method="post"
            action="<?=$intercom_moderation_action; ?>"
            onsubmit="return <?=$intercom_moderation_js; ?>"
            style="display: inline-block;"
        >
            <input type="hidden" name="intercom_action" value="<?=$message["is_moderated"] ? "restore" : "moderate"; ?>" />
            <input type="hidden" name="current_subject" value="<?=$subject["id"]; ?>" />
            <input
                type="button"
                onclick="<?=$intercom_moderation_js; ?>"
                value="<?=$message["is_moderated"] ? $Dictionnary["RestoreIntercomMessage"] : $Dictionnary["ModerateIntercomMessage"]; ?>"
                style="font-size: x-small; min-height: 20px;"
            />
        </form>
    <?php } else if ($message["id_user"] != $User["id"] && !$message["is_moderated"]) { ?>
        <?php if ($message["reported_by_user"]) { ?>
            <span style="font-size: x-small; opacity: 1; font-weight: bold;">
                <?=$Dictionnary["IntercomMessageReported"]; ?>
            </span>
        <?php } else { ?>
            <form
                method="post"
                action="<?=$intercom_moderation_action; ?>"
                onsubmit="return <?=$intercom_moderation_js; ?>"
                style="display: inline-block;"
            >
                <input type="hidden" name="intercom_action" value="report" />
                <input type="hidden" name="current_subject" value="<?=$subject["id"]; ?>" />
                <input
                    type="button"
                    onclick="<?=$intercom_moderation_js; ?>"
                    value="<?=$Dictionnary["ReportIntercomMessage"]; ?>"
                    style="font-size: x-small; min-height: 20px;"
                />
            </form>
        <?php } ?>
    <?php } ?>
</div>
